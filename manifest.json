{
  "manifest_version": 3,
  "name": "Porthole for Claude",
  "version": "1.19.0",
  "description": "Chat with Claude to control your browser",
  "permissions": [
    "tabs",
    "activeTab",
    "webRequest",
    "storage",
    "cookies",
    "clipboardRead",
    "clipboardWrite",
    "history",
    "downloads",
    "downloads.open",
    "browsingData",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Porthole for Claude",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "sidebar/lib/browser-polyfill.min.js",
        "content/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options/options.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "clean-text": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Clean excessive blank lines in focused text field"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
